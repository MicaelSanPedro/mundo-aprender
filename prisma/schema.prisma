generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id               String   @id
  customerName     String
  customerEmail    String
  customerWhatsapp String
  total            Float
  status           String   @default("pendente")
  paymentId        String?
  emailSent        Boolean  @default(false)
  items            String   
  createdAt        DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DownloadToken {
  token          String   @id
  productId      Int
  expiresAt      DateTime
  downloadsLeft  Int      @default(3)
  createdAt      DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
